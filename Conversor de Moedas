using System.Collections;

Console.OutputEncoding = System.Text.Encoding.UTF8;
float moeda, ConversorReal, resultado;
int escolha;
float Dolar = 5.49f;
float Euro = 6.33f;
float Libra = 6.99f;
Console.WriteLine("Conversos de Moedas");
Console.WriteLine("Digite o Valor em Reais que você quer Converter: ");
float.TryParse(Console.ReadLine(), out moeda);
Console.WriteLine("\n digite 1 para converter para Dolar \n digite 2 para converter para Euro \n digite 3 para converter para Libra");
int.TryParse(Console.ReadLine(), out escolha);
switch (escolha)
{
    case 1:
        Console.Write("Digite o Valor do Dolar: ");
        float.TryParse(Console.ReadLine()!.Replace(".", ","), out ConversorReal);
        resultado = moeda * Dolar;
        Console.WriteLine($"R$ {moeda} x U${Dolar} = R${resultado}");
        break;
    default:
        Console.WriteLine("Digite um Valor Válido");
        break;

    case 2:

        Console.Write("Digite o Valor do Euro: ");
        float.TryParse(Console.ReadLine()!.Replace(".", ","), out ConversorReal);
        resultado = moeda * Euro;
        Console.WriteLine($"R$ {moeda} x €{Euro} = R${resultado}");
        break;

    case 3:

        Console.Write("Digite o Valor da Libra: ");
        float.TryParse(Console.ReadLine()!.Replace(".", ","), out ConversorReal);
        resultado = moeda * Libra;
        Console.WriteLine($"R$ {moeda} x £{Libra} = R${resultado}");
        break;
}
